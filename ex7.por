programa {

  funcao inicio() {
    
real primeiraNota
real segundaNota
real terceiraNota 
real quartaNota

escreva ("sua primeira nota eh: ")
leia(primeiraNota)

escreva ("sua segunda nota eh: ")
leia(segundaNota)

escreva ("sua terceira nota eh: ")
leia(terceiraNota)

escreva ("sua quarta nota eh: ")
leia(quartaNota)

escreva("sua media e: ",  primeiraNota + segundaNota + terceiraNota + quartaNota / 4)
  
  }
}
